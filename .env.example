############################################################
# Copy this file to `.env` and fill in your credentials.
# The app auto-loads .env when run from PowerShell/terminal.
############################################################

# ── API Keys ──────────────────────────────────────────────
POLYGON_API_KEY=your_polygon_api_key_here
ALPACA_API_KEY_ID=your_alpaca_key_id_here
ALPACA_API_SECRET_KEY=your_alpaca_secret_key_here
TIINGO_API_KEY=your_tiingo_api_key_here

# AI providers (for AI Research tabs)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── ClickHouse (remote data store, replaces local parquets) ─
# CLICKHOUSE_HOST=abc123.clickhouse.cloud
# CLICKHOUSE_PORT=8443
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=
# CLICKHOUSE_DATABASE=default

# ── Data Directories ─────────────────────────────────────
# Parquet files (daily OHLCV + signals index)
PER_TICKER_PARQUET_DIR=/data/parquet
PER_TICKER_MINUTE_DIR=/data/minute

# ── Bloomberg Spreadsheets (optional, for Global tabs) ───
# Override these when running outside your home machine.
# If the file doesn't exist, the tab degrades gracefully.
# FUTURES_SPREADSHEET=/data/spreadsheets/Futures Spread2xlsb (version 1).xlsx
# TEN_DAY_SCREEN=/data/spreadsheets/10Day Screen 2025v2.xls
# PARITY_SHEET=/data/spreadsheets/PARITY SHEET (9).xlsx
# BETA_UNIVERSE=/data/spreadsheets/BETA Universe.xlsx

# ── Docker Compose host paths (used in docker-compose.yml) ─
# PARQUET_HOST_DIR=C:/Users/<you>/Documents/Visual Code/Polygon Data/per_ticker_daily_ohlcv
# MINUTE_HOST_DIR=C:/Users/<you>/Documents/Visual Code/Polygon Data/per_ticker_minute
# SPREADSHEETS_DIR=C:/Users/<you>/Documents
